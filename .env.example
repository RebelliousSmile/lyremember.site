# Turso (SQLite serverless) — https://turso.tech
# turso db create lyremember-waitlist
# turso db show lyremember-waitlist --url
# turso db tokens create lyremember-waitlist
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# Resend (notifications email admin) — https://resend.com
# Créer un compte, vérifier votre domaine, générer une API key
RESEND_API_KEY=re_xxxxxxxxxxxx

# Adresse qui reçoit les notifications à chaque inscription
NOTIFY_EMAIL=vous@scriptami.com
